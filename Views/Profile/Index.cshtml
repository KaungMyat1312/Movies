@model MVCMovie.Models.ApplicationUser

@{
    ViewData["Title"] = "My Profile";
}

<div class="container" style="margin-top: 50px; color: white; max-width: 600px;">
    <h2 style="margin-bottom: 30px;">Profile Information</h2>

    <div style="background: #1a1e26; padding: 30px; border-radius: 8px; border: 1px solid #2d3542;">
        <div style="margin-bottom: 20px;">
            <label style="color: #8a8d93; font-size: 0.9rem; display: block; margin-bottom: 5px;">Username / Email</label>
            <input type="text" value="@Model.UserName" class="form-control" readonly style="background: #11141a; color: white; border: 1px solid #2d3542;" />
        </div>

        <div style="margin-top: 30px; display: flex; gap: 15px;">
            <a asp-action="Favourites" class="btn btn-danger" style="padding: 10px 20px;">
                <i class='bx bxs-heart'></i> My Favourites
            </a>
            <a asp-action="Saved" class="btn btn-primary" style="padding: 10px 20px;">
                <i class='bx bxs-bookmark'></i> My Saved List
            </a>                                                                                                                                                                                                
        </div>
    </div>
</div>