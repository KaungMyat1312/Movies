@model MVCMovie.Models.Category

@{
    ViewData["Title"] = "Delete Category - DatShin";
}

<link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

<div class="container">
    <div class="categories-management-container" style="max-width: 600px; margin: 120px auto 50px auto;">

        <div class="page-header-area" style="border-bottom: 2px solid #dc3545;">
            <h2 class="page-title" style="color: #dc3545;">
                <i class='bx bx-error-circle' style="vertical-align: middle; margin-right: 8px;"></i>Confirm Delete
            </h2>
        </div>

        <div class="text-center py-3">
            <h5 style="color: #e2e8f0; font-weight: 500; margin-bottom: 20px;">
                Are you sure you want to permanently delete this category?
            </h5>

            <div style="background: rgba(220, 53, 69, 0.1); border: 1px solid rgba(220, 53, 69, 0.2); padding: 20px; border-radius: 6px; margin-bottom: 25px;">
                <span style="color: rgba(255,255,255,0.4); font-size: 0.85rem; uppercase; display: block; margin-bottom: 5px;">Category Name</span>
                <h3 style="color: #fff; font-weight: 700; margin: 0;">@Model.CategoryName</h3>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p style="color: #8a8d93; font-size: 0.9rem; margin-top: 10px; margin-bottom: 0;">
                        @Model.Description
                    </p>
                }
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="CategoryId" />

            <div class="d-flex justify-content-between mt-3" style="border-top: 1px solid rgba(255,255,255,0.05); pt-3">
                <a asp-action="Index" class="btn btn-back" style="margin-top: 15px;">
                    <i class='bx bx-x' style="vertical-align: middle; font-size: 1.1rem;"></i> Cancel
                </a>

                <button type="submit" class="btn btn-submit" style="background-color: #dc3545 !important; border-color: #dc3545 !important; color: #fff !important; margin-top: 15px;">
                    <i class='bx bx-trash' style="vertical-align: middle; margin-right: 4px;"></i> Yes, Delete
                </button>
            </div>
        </form>

    </div>
</div>