@model MVCMovie.Models.Movie

@{
    ViewData["Title"] = Model.Title + " - Details";

    // Fallback poster logic if PosterUrl is null or empty
    var hasPoster = !string.IsNullOrEmpty(Model.PosterUrl);
    var posterSrc = hasPoster && Model.PosterUrl!.StartsWith("http")
        ? Model.PosterUrl
        : Url.Content("~/" + (hasPoster ? Model.PosterUrl : "images/no-poster.png"));
}

<link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" />
<link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

<div class="container py-4">
    <div class="details-wrapper">
        <!-- Safely render background blur dynamic styling -->
        <div class="details-bg-blur" style="background-image: url('@posterSrc');"></div>

        <div class="row details-content g-4">

            <!-- Movie Poster Section -->
            <div class="col-md-4 text-center">
                <img src="@posterSrc" alt="@Model.Title" class="movie-detail-poster">
            </div>

            <!-- Movie Info Content Section -->
            <div class="col-md-8 d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                        <h1 class="text-white fw-bold m-0" style="font-size: 2.3rem;">@Model.Title</h1>
                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")" style="padding: 6px 12px; font-weight: 600;">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </div>

                    <div class="d-flex flex-wrap align-items-center gap-3 mb-4 mt-2">
                        <span class="badge bg-warning text-dark px-2 py-1 fw-bold">R</span>
                        <span class="meta-item"><i class='bx bx-time-five' style="color: #ffc107;"></i> @Model.Duration Mins</span>
                        <span style="color: rgba(255,255,255,0.2);">|</span>
                        <span class="meta-item"><i class='bx bx-calendar' style="color: #ffc107;"></i> @Model.ReleaseDate.ToString("yyyy MMMM dd")</span>
                    </div>

                    <hr style="border-top: 1px solid rgba(255,255,255,0.1); margin: 20px 0;">

                    <h5 style="color: #ffc107; font-weight: 700; margin-bottom: 12px;">Description</h5>
                    <p style="color: #cbd5e1; line-height: 1.7; font-size: 1.05rem; text-align: justify; margin-bottom: 25px;">
                        @(string.IsNullOrEmpty(Model.Description) ? "No description available for this movie." : Model.Description)
                    </p>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="info-card">
                                <h6 style="color: #8a8d93; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 6px; margin-bottom: 8px;">
                                    <i class='bx bxs-star' style="color: #ffc107; font-size: 1.1rem;"></i> IMDb Rating
                                </h6>
                                <p class="fw-bold text-white m-0" style="font-size: 1.3rem;">
                                    @Model.Rating <span style="font-size: 0.9rem; color: #8a8d93; font-weight: 400;">/ 10</span>
                                </p>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="info-card d-flex flex-column justify-content-center">
                                <h6 style="color: #8a8d93; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: flex; align-items: center; gap: 6px;">
                                    <i class='bx bx-video' style="color: #ffc107; font-size: 1.1rem;"></i> Official Trailer
                                </h6>
                                @if (!string.IsNullOrEmpty(Model.TrailerUrl))
                                {
                                    <a href="@Model.TrailerUrl" target="_blank" class="watch-btn" style="padding: 6px 16px; font-size: 0.9rem; width: fit-content; text-decoration: none; display: inline-flex; align-items: center; gap: 4px;">
                                        <i class='bx bx-play-circle'></i> Watch Trailer
                                    </a>
                                }
                                else
                                {
                                    <span style="color: #64748b; font-size: 0.95rem; font-style: italic;">No Trailer Available</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer Action Buttons -->
                <div class="d-flex flex-wrap gap-2 mt-5 pt-3" style="border-top: 1px solid rgba(255,255,255,0.08);">
                    <a asp-action="Index" class="btn btn-back">
                        <i class='bx bx-arrow-back'></i> Back to List
                    </a>

                    @if (User.IsInRole("Admin") || User.Identity?.Name?.ToLower() == "admin@movie.com")
                    {
                        <!-- 🎯 Edit Action Link with correct Id Route binding -->
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-submit ms-auto">
                            <i class='bx bx-edit-alt'></i> Edit Movie
                        </a>
                    }
                    else
                    {
                        <div class="ms-auto d-flex gap-2">
                            <!-- Favourite Form & Toggle Button -->
                            <form asp-controller="Profile" asp-action="AddToFavourite" method="post" style="display: inline;">
                                <input type="hidden" name="movieId" value="@Model.Id" />
                                @if (ViewBag.IsFavorited == true)
                                {
                                    <button type="submit" class="btn-action-outline text-danger active" style="background-color: rgba(220, 53, 69, 0.1); border-color: #dc3545;">
                                        <i class='bx bxs-heart'></i> Favourited
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn-action-outline text-danger">
                                        <i class='bx bx-heart'></i> Favourite
                                    </button>
                                }
                            </form>

                            <!-- Watch Later Form & Toggle Button -->
                            <form asp-controller="Profile" asp-action="AddToSave" method="post" style="display: inline;">
                                <input type="hidden" name="movieId" value="@Model.Id" />
                                @if (ViewBag.IsSaved == true)
                                {
                                    <button type="submit" class="btn-action-outline text-info active" style="background-color: rgba(13, 202, 240, 0.1); border-color: #0dcaf0;">
                                        <i class='bx bxs-bookmark'></i> Saved
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn-action-outline text-info">
                                        <i class='bx bx-bookmark'></i> Save
                                    </button>
                                }
                            </form>
                        </div>
                    }
                </div>

            </div>
        </div>

    </div>
</div>