@model MVCMovie.Models.Movie

@{
    ViewData["Title"] = "Movie Details";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"> Movie Details</h4>
            <div>
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactive</span>
                }
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    @if (!string.IsNullOrEmpty(Model.PosterUrl))
                    {
                        <img src="@Model.PosterUrl" alt="@Model.Title Poster" class="img-fluid rounded shadow-sm" style="max-height: 450px; width: 100%; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center rounded border" style="height: 400px;">
                            <span class="text-muted">No Poster Available</span>
                        </div>
                    }
                </div>

                <div class="col-md-8">
                    <h2 class="text-primary mb-2">@Model.Title</h2>
                    <p class="text-muted mb-4"><span class="badge bg-secondary me-2">@Model.Rating</span> | <i class="bi bi-clock"></i> @Model.Duration Mins</p>

                    <h5 class="fw-bold">Description</h5>
                    <p class="text-secondary" style="line-height: 1.6; text-align: justify;">
                        @(string.IsNullOrEmpty(Model.Description) ? "No description provided for this movie." : Model.Description)
                    </p>

                    <hr />

                    <div class="row g-3">
                        <div class="col-sm-4">
                            <span class="text-muted d-block">Release Date</span>
                            <strong>@Model.ReleaseDate.ToString("yyyy MMMM dd")</strong>
                        </div>
                        <div class="col-sm-8">
                            <span class="text-muted d-block">Trailer Link</span>
                            @if (!string.IsNullOrEmpty(Model.TrailerUrl))
                            {
                                <a href="@Model.TrailerUrl" target="_blank" class="btn btn-sm btn-outline-danger mt-1">
                                    <i class="bi bi-youtube"></i> Watch Trailer
                                </a>
                            }
                            else
                            {
                                <span class="text-muted">No trailer link available</span>
                            }
                        </div>
                    </div>

                    <div class="d-flex justify-content-between border-top mt-5 pt-3">
                        <div class="d-flex gap-2">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>

                            <button class="btn btn-outline-danger favourite-btn" data-movie-id="@Model.Id">
                                ❤️ <span class="fav-text">Favourite</span>
                            </button>

                            <button class="btn btn-outline-primary save-btn" data-movie-id="@Model.Id">
                                🔖 <span class="save-text">Save</span>
                            </button>
                        </div>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning px-4 text-dark fw-bold">
                                <i class="bi bi-pencil-square"></i> Edit Movie
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // --- 1. Favourite AJAX ---
            const favBtn = document.querySelector('.favourite-btn');
            if (favBtn) {
                favBtn.addEventListener('click', async function () {
                    const movieId = this.getAttribute('data-movie-id');
                    const textSpan = this.querySelector('.fav-text');

                    try {
                        const response = await fetch('/api/movies/toggle-favourite', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(parseInt(movieId))
                        });

                        if (response.ok) {
                            const result = await response.json();
                            if (result.isFavourite) {
                                this.classList.remove('btn-outline-danger');
                                this.classList.add('btn-danger');
                                textSpan.textContent = 'Favorited';
                            } else {
                                this.classList.remove('btn-danger');
                                this.classList.add('btn-outline-danger');
                                textSpan.textContent = 'Favourite';
                            }
                        } else if (response.status === 401) {
                            alert("Please login first to favourite this movie!");
                        }
                    } catch (error) {
                        console.error("Error toggling favourite:", error);
                    }
                });
            }

            // --- 2. Save AJAX ---
            const saveBtn = document.querySelector('.save-btn');
            if (saveBtn) {
                saveBtn.addEventListener('click', async function () {
                    const movieId = this.getAttribute('data-movie-id');
                    const textSpan = this.querySelector('.save-text');

                    try {
                        const response = await fetch('/api/movies/toggle-save', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(parseInt(movieId))
                        });

                        if (response.ok) {
                            const result = await response.json();
                            if (result.isSaved) {
                                this.classList.remove('btn-outline-primary');
                                this.classList.add('btn-primary');
                                textSpan.textContent = 'Saved';
                            } else {
                                this.classList.remove('btn-primary');
                                this.classList.add('btn-outline-primary');
                                textSpan.textContent = 'Save';
                            }
                        } else if (response.status === 401) {
                            alert("Please login first to save this movie!");
                        }
                    } catch (error) {
                        console.error("Error toggling save:", error);
                    }
                });
            }

        });
    </script>
}