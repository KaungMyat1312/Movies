@model MVCMovie.ViewModels.MovieFormViewModel
@{
    ViewData["Title"] = "Edit - " + Model.Title;

    var hasPoster = !string.IsNullOrEmpty(Model.PosterUrl);
    var posterSrc = hasPoster && Model.PosterUrl!.StartsWith("http")
        ? Model.PosterUrl
        : Url.Content("~/" + (hasPoster ? Model.PosterUrl : "images/no-poster.png"));
}

<link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" />
<link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

<div class="container py-4">
    <div class="details-wrapper">
        <!-- Dynamic Background Blur Layer -->
        <div class="details-bg-blur" style="background-image: url('@posterSrc');"></div>

        <!-- FORM START -->
        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="row details-content g-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PosterUrl" />

            <!-- Movie Poster Display Area -->
            <div class="col-md-4 text-center">
                <img src="@posterSrc" alt="@Model.Title" class="movie-detail-poster mb-3">

                <div class="mb-3 text-start">
                    <label asp-for="PosterUrl" class="form-label text-warning fw-bold">Poster URL (Optional)</label>
                    <input asp-for="PosterUrl" class="form-control bg-dark text-white border-secondary" placeholder="https://example.com/poster.jpg" />
                    <span asp-validation-for="PosterUrl" class="text-danger small"></span>
                </div>
            </div>

            <!-- Movie Editable Fields Area -->
            <div class="col-md-8 d-flex flex-column justify-content-between">
                <div>
                    <h2 class="text-white fw-bold mb-4" style="border-bottom: 2px solid #ffc107; padding-bottom: 8px; width: fit-content;">
                        <i class='bx bx-edit'></i> Edit Movie Details
                    </h2>

                    <!-- Title & Active Status Row -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label text-warning fw-bold">Movie Title</label>
                            <input asp-for="Title" class="form-control bg-dark text-white border-secondary" required />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch">
                                <label class="form-check-label text-white fw-bold" for="isActiveSwitch">Is Active Status</label>
                            </div>
                        </div>
                    </div>

                    <!-- Duration, Rating & Release Date Row -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="Duration" class="form-label text-warning fw-bold">Duration (Minutes)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-secondary text-white border-secondary"><i class='bx bx-time-five'></i></span>
                                <input asp-for="Duration" type="number" class="form-control bg-dark text-white border-secondary" required />
                            </div>
                            <span asp-validation-for="Duration" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Rating" class="form-label text-warning fw-bold">IMDb Rating</label>
                            <div class="input-group">
                                <span class="input-group-text bg-secondary text-white border-secondary"><i class='bx bxs-star'></i></span>
                                <input asp-for="Rating" type="number" step="0.1" min="0" max="10" class="form-control bg-dark text-white border-secondary" required />
                            </div>
                            <span asp-validation-for="Rating" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ReleaseDate" class="form-label text-warning fw-bold">Release Date</label>
                            <input asp-for="ReleaseDate" type="date" class="form-control bg-dark text-white border-secondary" required />
                            <span asp-validation-for="ReleaseDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Trailer URL Input -->
                    <div class="mb-3">
                        <label asp-for="TrailerUrl" class="form-label text-warning fw-bold">Official Trailer URL</label>
                        <div class="input-group">
                            <span class="input-group-text bg-secondary text-white border-secondary"><i class='bx bx-video'></i></span>
                            <input asp-for="TrailerUrl" class="form-control bg-dark text-white border-secondary" placeholder="https://www.youtube.com/watch?v=..." />
                        </div>
                        <span asp-validation-for="TrailerUrl" class="text-danger small"></span>
                    </div>

                    <!-- Description Input -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label text-warning fw-bold">Description</label>
                        <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="4" placeholder="Enter movie summary here..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Categories Checkboxes -->
                    <!-- Categories Checkboxes -->
                    @if (Model.AvailableCategories != null && Model.AvailableCategories.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label text-warning fw-bold d-block">Genres / Categories</label>
                            <div class="d-flex flex-wrap gap-3 p-3 rounded bg-dark" style="border: 1px solid rgba(255,255,255,0.1);">
                                @for (int i = 0; i < Model.AvailableCategories.Count; i++)
                                {
                                    <div class="form-check">
                                        <input type="hidden" asp-for="AvailableCategories[i].CategoryId" />
                                        <input type="hidden" asp-for="AvailableCategories[i].CategoryName" />
                                        <input type="checkbox" asp-for="AvailableCategories[i].IsSelected" class="form-check-input" id="cat_@i" />

                                        <label class="form-check-label text-white" for="cat_@i">
                                            @Model.AvailableCategories[i].CategoryName
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Bottom Form Buttons -->
                <div class="d-flex flex-wrap gap-2 mt-4 pt-3" style="border-top: 1px solid rgba(255,255,255,0.08);">
                    <a asp-action="Index" class="btn btn-back text-decoration-none">
                        <i class='bx bx-arrow-back'></i> Cancel
                    </a>

                    <button type="submit" class="btn btn-submit ms-auto">
                        <i class='bx bx-save'></i> Save Changes
                    </button>
                </div>

            </div>
        </form>
        <!-- FORM END -->
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}