@model MVCMovie.ViewModels.MovieFormViewModel
@{
    ViewData["Title"] = "Create Movie";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">+ Add New Movie</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" placeholder="Enter movie title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter movie description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ReleaseDate" class="form-label fw-bold"></label>
                                <input asp-for="ReleaseDate" class="form-control" type="date" />
                                <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Duration" class="form-label fw-bold">Duration (Minutes)</label>
                                <input asp-for="Duration" class="form-control" type="number" placeholder="e.g. 120" />
                                <span asp-validation-for="Duration" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Rating" class="form-label fw-bold">IMDb Rating</label>
                                <input asp-for="Rating" class="form-control" placeholder="e.g. 7.3, 8.5" />
                                <span asp-validation-for="Rating" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3 d-flex align-items-center mt-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                                    <label class="form-check-label fw-bold" asp-for="IsActive">Is Active (Visible to users)</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold d-block">Movie Categories / Genres</label>
                            <div class="p-3 border rounded bg-light" style="max-height: 200px; overflow-y: auto;">
                                @if (Model.AvailableCategories != null && Model.AvailableCategories.Any())
                                {
                                    <div class="row">
                                        @for (int i = 0; i < Model.AvailableCategories.Count; i++)
                                        {
                                            <div class="col-md-4 mb-2">
                                                <div class="form-check">
                                                    <input type="hidden" asp-for="@Model.AvailableCategories[i].CategoryId" />
                                                    <input type="hidden" asp-for="@Model.AvailableCategories[i].CategoryName" />
                                                    <input class="form-check-input" type="checkbox" asp-for="@Model.AvailableCategories[i].IsSelected" id="cat_@i" />
                                                    <label class="form-check-label text-dark" for="cat_@i">
                                                        @Model.AvailableCategories[i].CategoryName
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">No categories available in database.</span>
                                }
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PosterUrl" class="form-label fw-bold"></label>
                            <input asp-for="PosterUrl" class="form-control" placeholder="Image URL or Path" />
                            <span asp-validation-for="PosterUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TrailerUrl" class="form-label fw-bold"></label>
                            <input asp-for="TrailerUrl" class="form-control" placeholder="e.g. YouTube Video Link" />
                            <span asp-validation-for="TrailerUrl" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3">
                            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                            <button type="submit" class="btn btn-success px-4">Create Movie</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}