@model IEnumerable<MVCMovie.Models.Movie>

@{
    ViewData["Title"] = "Home - DatShin";

    var displayMovies = Model != null
        ? (User.IsInRole("Admin") ? Model : Model.Where(m => m.IsActive))
        : Enumerable.Empty<MVCMovie.Models.Movie>();

    bool isSearch = ViewData["IsSearch"] as bool? ?? false;
}

@if (!isSearch)
{
    <section class="home custom-container" id="home">
        <div class="swiper mySwiper">
            <div class="swiper-wrapper">
                @if (displayMovies != null && displayMovies.Any())
                {
                    @foreach (var movie in displayMovies.Take(3))
                    {
                        <div class="swiper-slide">
                            <img src="@(!string.IsNullOrEmpty(movie.PosterUrl) && movie.PosterUrl.StartsWith("http") ? movie.PosterUrl : Url.Content("~/" + (movie.PosterUrl ?? "images/no-poster.png")))"
                                 alt="@(movie.Title ?? "No Title")"
                                 class="home-img"
                                 style="object-fit: cover; object-position: center;">

                            <div class="home-text">
                                <h1 class="home-title">@(movie.Title ?? "Untitled Movie")</h1>
                                <p class="home-meta">
                                    <i class='bx bx-time-five'></i> @movie.Duration mins |
                                    <i class='bx bxs-star' style="color: var(--main-color);"></i> @movie.Rating |
                                    <i class='bx bx-calendar'></i> @movie.ReleaseDate.ToString("yyyy")
                                </p>
                                <div class="watch-btn-container">
                                    <a asp-action="Details" asp-route-id="@movie.Id" class="watch-btn">
                                        <i class="bx bx-play"></i> <span>Watch</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="swiper-button-next" id="hero-next"></div>
            <div class="swiper-button-prev" id="hero-prev"></div>
        </div>
    </section>
}


<section class="movies custom-container" id="movies" style="margin-top: @(isSearch ? "40px" : "0px");">
    <div class="heading-area" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
        <h2 class="heading-title" style="margin: 0;">@(isSearch ? "Search Results" : "Trending Movies")</h2>

        @if (isSearch)
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary" style="color: #fff; border-color: rgba(255,255,255,0.3);">Clear Search</a>
        }
    </div>

    @if (displayMovies != null && displayMovies.Any())
    {
        @if (isSearch)
        {
            <div class="movies-search-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px;">
                @foreach (var movie in displayMovies)
                {
                    <div class="movie-box-item" style="position: relative;">
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="admin-controls"
                                 onclick="event.stopPropagation();"
                                 style="position: absolute; top: 10px; right: 10px; z-index: 99999 !important; display: flex; gap: 12px; background: rgba(30, 35, 45, 0.85) !important; backdrop-filter: blur(5px); padding: 6px 14px; border-radius: 6px; border: 1px solid rgba(255, 255, 255, 0.1) !important;">
                                <a asp-controller="Movies" asp-action="Edit" asp-route-id="@movie.Id" class="text-warning" style="text-decoration: none; font-weight: 700;">
                                    <i class='bx bx-edit-alt'></i> Edit
                                </a>
                                <span style="color: rgba(255,255,255,0.2);">|</span>
                                <a asp-controller="Movies" asp-action="Delete" asp-route-id="@movie.Id" class="text-danger" style="text-decoration: none; font-weight: 700;">
                                    <i class='bx bx-trash'></i> Delete
                                </a>
                            </div>
                        }

                        <a asp-action="Details" asp-route-id="@movie.Id" class="movie-img-link">
                            <img src="@(!string.IsNullOrEmpty(movie.PosterUrl) && movie.PosterUrl.StartsWith("http") ? movie.PosterUrl : Url.Content("~/" + (movie.PosterUrl ?? "images/no-poster.png")))" alt="@(movie.Title ?? "No Title")" class="movie-poster-img" style="width: 100%; height: 320px; object-fit: cover; border-radius: 8px;">
                        </a>

                        <div class="box-text" style="padding-top: 10px;">
                            <h2 class="movie-text" style="font-size: 1.1rem; margin-bottom: 5px;">@(movie.Title ?? "Untitled Movie")</h2>
                            <span class="movietype">
                                <i class='bx bx-time-five'></i> @movie.Duration mins |
                                <i class='bx bxs-star' style="color: var(--main-color);"></i> @movie.Rating
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="movies-swiper-wrapper" style="position: relative;">
                <div class="movies-content swiper">
                    <div class="swiper-wrapper">
                        @foreach (var movie in displayMovies)
                        {
                            <div class="swiper-slide">
                                <div class="movie-box-item">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="admin-controls"
                                             onclick="event.stopPropagation();"
                                             style="position: absolute; top: 10px; right: 10px; z-index: 99999 !important; display: flex; gap: 12px; background: rgba(30, 35, 45, 0.85) !important; backdrop-filter: blur(5px); padding: 6px 14px; border-radius: 6px; border: 1px solid rgba(255, 255, 255, 0.1) !important;">
                                            <a asp-controller="Movies" asp-action="Edit" asp-route-id="@movie.Id" class="text-warning" style="text-decoration: none; font-weight: 700;">
                                                <i class='bx bx-edit-alt'></i> Edit
                                            </a>
                                            <span style="color: rgba(255,255,255,0.2); align-self: center;">|</span>
                                            <a asp-controller="Movies" asp-action="Delete" asp-route-id="@movie.Id" class="text-danger" style="text-decoration: none; font-weight: 700;">
                                                <i class='bx bx-trash'></i> Delete
                                            </a>
                                        </div>
                                    }

                                    <a asp-action="Details" asp-route-id="@movie.Id" class="movie-img-link">
                                        <img src="@(!string.IsNullOrEmpty(movie.PosterUrl) && movie.PosterUrl.StartsWith("http") ? movie.PosterUrl : Url.Content("~/" + (movie.PosterUrl ?? "images/no-poster.png")))" alt="@(movie.Title ?? "No Title")" class="movie-poster-img">
                                    </a>

                                    <div class="box-text">
                                        <h2 class="movie-text">@(movie.Title ?? "Untitled Movie")</h2>
                                        <span class="movietype">
                                            <i class='bx bx-time-five'></i> @movie.Duration mins |
                                            <i class='bx bxs-star' style="color: var(--main-color);"></i> @movie.Rating
                                        </span>

                                        <div class="watch-btn-container" style="margin-top: 12px;">
                                            <a asp-action="Details" asp-route-id="@movie.Id" class="watch-btn">
                                                <i class="bx bx-play"></i> <span>Watch</span>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="swiper-button-next" id="movies-next"></div>
                <div class="swiper-button-prev" id="movies-prev"></div>
            </div>
        }
    }
    else
    {
        <div class="no-results-card text-center py-5 px-3" style="background: #11141a; border: 1px dashed rgba(255, 255, 255, 0.1); border-radius: 8px; margin-top: 20px;">
            <i class='bx bx-search-alt' style="font-size: 3.5rem; color: var(--main-color); margin-bottom: 15px; display: block;"></i>
            <h4 class="text-white" style="font-weight: 600;">No Movies Found</h4>
            <p style="color: #8a8d93; font-size: 0.9rem; margin-bottom: 0;">
                We couldn't find any results matching your search criteria.
            </p>
        </div>
    }
</section>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
}