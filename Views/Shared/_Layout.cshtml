<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DatShin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link rel="stylesheet" href="~/css/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
</head>
<body>
    <header>
        <div class="nav custom-container" style="display: flex; align-items: center; justify-content: space-between;">
            <a asp-controller="Movies" asp-action="Index" style="font-size: 2rem; font-weight: 700; color: #fff; text-decoration: none; display: flex; align-items: center; gap: 8px;">
                Dat<span style="color: var(--main-color);">Shin</span> <i class='bx bx-camera-movie' style="color: var(--main-color);"></i>
            </a>

            <div class="search-box-container">
                <form asp-controller="Movies" asp-action="Index" method="get" class="search-form">
                    <input type="text" name="searchString" placeholder="search movie" class="search-input" />
                    <button type="submit" class="search-submit-btn">
                        <i class='bx bx-search'></i>
                    </button>
                </form>
            </div>

            <div class="login-section" style="display: flex; align-items: center;">
                <partial name="_LoginPartial" />
            </div>
        </div>
    </header>

    <div class="navbar">
        <a asp-controller="Movies" asp-action="Index" class="nav-link">
            <i class='bx bx-home'></i><span class="nav-link-title">Home</span>
        </a>
        <a asp-controller="Movies" asp-action="Index" class="nav-link">
            <i class='bx bxs-hot'></i><span class="nav-link-title">Trending</span>
        </a>
        <a asp-controller="Movies" asp-action="Favourites" class="nav-link">
            <i class='bx bxs-heart'></i><span class="nav-link-title">Favourites</span>
        </a>
        <a asp-controller="Movies" asp-action="Saved" class="nav-link">
            <i class='bx bxs-bookmark'></i><span class="nav-link-title">Watch Later</span>
        </a>
    </div>

    @RenderBody()

    <div class="coyright">
        <p>&#169; DAT Shin All right Copy reserve </p>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/swiper-bundle.min.js"></script>
    <script src="~/js/main.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>