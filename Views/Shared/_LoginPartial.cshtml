@using Microsoft.AspNetCore.Identity
@using MVCMovie.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="login-menu">
    @if (SignInManager.IsSignedIn(User))
    {
        var isAdmin = User.IsInRole("Admin");
        var isViewer = User.IsInRole("Viewer");

        @if (!isViewer && !isAdmin)
        {
            <li class="nav-item">
                <span class="user-name me-3">
                    <i class='bx bx-user-circle'></i> @User.Identity?.Name
                </span>
            </li>
        }

        <li class="nav-item">
            <span class="user-name me-3">
                <i class='bx bx-user-circle'></i> @User.Identity?.Name
            </span>
        </li>

        @if (isAdmin)
        {
            <li class="nav-item" style="display: inline-flex; gap: 8px;">
                <a asp-area="" asp-controller="Categories" asp-action="Create" class="btn btn-outline-warning" style="font-weight: 600; padding: 6px 15px; border-radius: 4px; border: 1px solid #ffc107; color: #ffc107; text-decoration: none;">
                    <i class='bx bx-list-ul' style="vertical-align: middle; margin-right: 4px;"></i> Manage Movie
                </a>
                <a asp-area="" asp-controller="Movies" asp-action="Create" class="btn btn-warning" style="font-weight: 700; background-color: #ffc107; border: 1px solid #ffc107; color: #000; padding: 6px 15px; border-radius: 4px; text-decoration: none;">
                    <i class='bx bx-plus-circle' style="vertical-align: middle; margin-right: 4px;"></i> Create Movie
                </a>
            </li>
        }

        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Movies", new { area = "" })">
                <button type="submit" class="btn btn-outline-light btn-sm logout-btn">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link register-btn" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="btn login-btn" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>