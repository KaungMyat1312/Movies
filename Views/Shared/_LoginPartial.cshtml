@using Microsoft.AspNetCore.Identity
@using MVCMovie.Models
@inject SignInManager<ApplicationUser> SignInManager

<ul style="list-style: none; margin: 0; padding: 0; display: flex; align-items: center; gap: 12px; flex-direction: row;">
    @if (SignInManager.IsSignedIn(User))
    {
        <li style="display: flex; align-items: center; white-space: nowrap;">
            <span style="color: #fff; font-size: 0.95rem; display: flex; align-items: center; gap: 5px;">
                <i class='bx bx-user-circle' style="font-size: 1.2rem; color: var(--main-color);"></i> @User.Identity?.Name
            </span>
        </li>

        @if (User.IsInRole("Admin"))
        {
            <li style="display: inline-block; white-space: nowrap;">
                <a asp-controller="Categories" asp-action="Index" style="background-color: transparent; color: #ffc107; font-weight: 600; border: 1px solid #ffc107; border-radius: 4px; padding: 6px 14px; text-decoration: none; font-size: 0.9rem; display: flex; align-items: center; gap: 4px; transition: 0.3s;">
                    <i class='bx bx-list-ul'></i> Manage Movie
                </a>
            </li>
            <li style="display: inline-block; white-space: nowrap;">
                <a asp-controller="Movies" asp-action="Create" style="background-color: #ffc107; color: #000; font-weight: bold; border: 1px solid #ffc107; border-radius: 4px; padding: 6px 14px; text-decoration: none; font-size: 0.9rem; display: flex; align-items: center; gap: 4px; transition: 0.3s;">
                    <i class='bx bx-plus-circle'></i> Create Movie
                </a>
            </li>
        }

        <li style="margin-left: 5px; display: inline-block; white-space: nowrap;">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Movies", new { area = "" })" method="post" style="margin: 0;">
                <button type="submit" style="background-color: #e50914; color: #fff; border: none; border-radius: 4px; padding: 6px 14px; font-weight: 500; font-size: 0.9rem; cursor: pointer; transition: 0.3s;">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li style="display: inline-block;"><a asp-area="Identity" asp-page="/Account/Register" style="color: #fff; text-decoration: none; font-size: 0.9rem;">Register</a></li>
        <li style="display: inline-block;"><a asp-area="Identity" asp-page="/Account/Login" style="color: var(--main-color); text-decoration: none; font-size: 0.9rem; font-weight: 600;">Login</a></li>
    }
</ul>